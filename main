import pyttsx3
from gtts import gTTS
import speech_recognition as sr
import whisper
import os
import requests
import time

class SpeechTasks:
    def __init__(self):
        print("Iniciando el gestor de tareas de voz...")

    # 1. Local Text to Speech (TTS)
    def local_tts(self, text):
        print("\n--- 1. Local TTS ---")
        print(f"Generando audio local para: '{text}'")
        # Inicializa pyttsx3 que usa el motor de voz nativo del sistema operativo (offline)
        engine = pyttsx3.init()
        engine.say(text)
        engine.runAndWait()

    # 2. Local Speech to Text (STT)
    def local_stt(self, audio_file_path):
        print("\n--- 2. Local STT ---")
        print(f"Transcribiendo localmente el archivo: {audio_file_path}")
        try:
            # Usamos Whisper en su versión 'tiny' para que corra rápido y en local
            model = whisper.load_model("tiny")
            result = model.transcribe(audio_file_path)
            print(f"Transcripción local: {result['text']}")
        except Exception as e:
            print(f"Error en Local STT: {e}")

    # 3. External API Text to Speech (TTS)
    def external_tts(self, text, output_file="output_external.mp3"):
        print("\n--- 3. External API TTS ---")
        print(f"Enviando texto a Google API para TTS: '{text}'")
        # gTTS hace una petición a la API de Google Translate
        tts = gTTS(text=text, lang='es')
        tts.save(output_file)
        print(f"Audio guardado exitosamente en: {output_file}")
       

    # 4. External API Speech to Text (STT)
    def external_stt(self, audio_file_path):
        print("\n--- 4. External API STT ---")
        print("Enviando audio a la API de Google para transcripción...")
        recognizer = sr.Recognizer()
        
        with sr.AudioFile(audio_file_path) as source:
            audio_data = recognizer.record(source)
            try:
                text = recognizer.recognize_google(audio_data, language="es-ES")
                print(f"Transcripción API Externa: {text}")
            except sr.UnknownValueError:
                print("La API no pudo entender el audio.")
            except sr.RequestError as e:
                print(f"No se pudo conectar con la API de Google; {e}")

 # 5. Inteligencia de Audio (Resumen/Detección de idioma)
    def advanced_audio_task(self, audio_url):
        print("\n--- 5. Advanced Audio Task (External API) ---")
        print("Tarea: Resumen automático de audio usando AssemblyAI (Requiere API Key)")
        
        #  API KEY de AssemblyAI 
        API_KEY = "TU_ASSEMBLYAI_API_KEY_AQUI" 
        
        if API_KEY == "TU_ASSEMBLYAI_API_KEY_AQUI":
            print(" Aviso: Reemplaza 'TU_ASSEMBLYAI_API_KEY_AQUI' con una clave válida para ver el resultado real.")
            return

        headers = {"authorization": API_KEY}
        endpoint = "https://api.assemblyai.com/v2/transcript"
        
        #  Summarization
        json_data = {
            "audio_url": audio_url,
            "summarization": True,
            "summary_model": "informative",
            "summary_type": "bullets"
        }
        
        response = requests.post(endpoint, json=json_data, headers=headers)
        transcript_id = response.json().get('id')
        
        # Esperamos a que la IA procese el audio
        print("Procesando inteligencia de audio...")
        while True:
            polling_response = requests.get(f"{endpoint}/{transcript_id}", headers=headers)
            status = polling_response.json().get('status')
            if status == 'completed':
                print("\n Resumen del audio generado:")
                print(polling_response.json().get('summary'))
                break
            elif status == 'error':
                print("Error al procesar el audio.")
                break
            time.sleep(3)               
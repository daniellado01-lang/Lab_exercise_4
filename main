import pyttsx3
from gtts import gTTS
import speech_recognition as sr
import whisper
import os
import requests
import time

class SpeechTasks:
    def __init__(self):
        print("Iniciando el gestor de tareas de voz...")

    # 1. Local Text to Speech (TTS)
    def local_tts(self, text):
        print("\n--- 1. Local TTS ---")
        print(f"Generando audio local para: '{text}'")
        # Inicializa pyttsx3 que usa el motor de voz nativo del sistema operativo (offline)
        engine = pyttsx3.init()
        engine.say(text)
        engine.runAndWait()

    # 2. Local Speech to Text (STT)
    def local_stt(self, audio_file_path):
        print("\n--- 2. Local STT ---")
        print(f"Transcribiendo localmente el archivo: {audio_file_path}")
        try:
            # Usamos Whisper en su versión 'tiny' para que corra rápido y en local
            model = whisper.load_model("tiny")
            result = model.transcribe(audio_file_path)
            print(f"Transcripción local: {result['text']}")
        except Exception as e:
            print(f"Error en Local STT: {e}")

    